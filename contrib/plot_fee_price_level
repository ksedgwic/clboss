#!/usr/bin/env python3
import argparse
import os
import sqlite3
from datetime import datetime


def parse_args():
    parser = argparse.ArgumentParser(
        description="Plot fee price_level over time for a peer."
    )
    parser.add_argument("peer", help="Peer nodeid (hex).")
    parser.add_argument(
        "--db",
        default=os.path.expanduser("~/bonsai/doc/data/clboss-fees.sqlite3"),
        help="Path to sqlite database.",
    )
    parser.add_argument(
        "--out",
        default="price_level.png",
        help="Output image path.",
    )
    parser.add_argument(
        "--show",
        action="store_true",
        help="Show the plot interactively.",
    )
    return parser.parse_args()


def parse_ts(ts):
    if ts.endswith("Z"):
        ts = ts[:-1] + "+00:00"
    return datetime.fromisoformat(ts)


def main():
    args = parse_args()
    conn = sqlite3.connect(args.db)
    rows = conn.execute(
        "SELECT ts, price_level FROM fee_change_events "
        "WHERE peer = ? ORDER BY ts",
        (args.peer,),
    ).fetchall()
    conn.close()

    ts = []
    levels = []
    for t, level in rows:
        if level is None:
            continue
        ts.append(parse_ts(t))
        levels.append(level)

    if not ts:
        raise SystemExit("no price_level data for peer")

    try:
        import matplotlib.pyplot as plt
    except ImportError:
        raise SystemExit("matplotlib is required to output graphs.")

    plt.figure(figsize=(12, 4))
    plt.plot(ts, levels, linewidth=1)
    plt.xlabel("time")
    plt.ylabel("price_level")
    plt.title(args.peer)
    plt.tight_layout()
    plt.savefig(args.out, dpi=150)

    if args.show:
        plt.show()


if __name__ == "__main__":
    main()
