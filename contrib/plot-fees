def main():
    parser = argparse.ArgumentParser(
        description="Plot fee-related time series from clboss fee logs."
    )
    subparsers = parser.add_subparsers(dest="view", required=True)

    price_parser = subparsers.add_parser(
        "price-level", help="Plot price_level over time."
    )
    add_common_args(price_parser)
    price_parser.set_defaults(func=plot_price_level)

    base_ppm_parser = subparsers.add_parser(
        "base-ppm", help="Plot est_base and est_ppm over time."
    )
    add_common_args(base_ppm_parser)
    base_ppm_parser.set_defaults(func=plot_base_ppm)

    size_mult_parser = subparsers.add_parser(
        "size-mult", help="Plot size_mult over time."
    )
    add_common_args(size_mult_parser)
    size_mult_parser.set_defaults(func=plot_size_mult)

    balance_mult_parser = subparsers.add_parser(
        "balance-mult", help="Plot balance_mult over time."
    )
    add_common_args(balance_mult_parser)
    balance_mult_parser.set_defaults(func=plot_balance_mult)

    args = parser.parse_args()
    args.from_ts = parse_time_arg(args.from_ts)
    args.to_ts = parse_time_arg(args.to_ts)

    args.func(args)


if __name__ == "__main__":
    main()
