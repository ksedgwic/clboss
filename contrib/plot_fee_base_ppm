#!/usr/bin/env python3
import argparse
import os
import sqlite3
from datetime import datetime


def parse_args():
    parser = argparse.ArgumentParser(
        description="Plot fee est_base and est_ppm over time for a peer."
    )
    parser.add_argument("peer", help="Peer nodeid (hex).")
    parser.add_argument(
        "--db",
        default=os.path.expanduser("~/bonsai/doc/data/clboss-fees.sqlite3"),
        help="Path to sqlite database.",
    )
    parser.add_argument(
        "--out",
        default=None,
        help="Output image path.",
    )
    parser.add_argument(
        "--show",
        action="store_true",
        help="Show the plot interactively.",
    )
    return parser.parse_args()


def parse_ts(ts):
    if ts.endswith("Z"):
        ts = ts[:-1] + "+00:00"
    return datetime.fromisoformat(ts)


def main():
    args = parse_args()
    conn = sqlite3.connect(args.db)
    rows = conn.execute(
        "SELECT ts, est_base, est_ppm FROM fee_change_events "
        "WHERE peer = ? ORDER BY ts",
        (args.peer,),
    ).fetchall()
    conn.close()

    ts = []
    bases = []
    ppms = []
    for t, base, ppm in rows:
        if base is None or ppm is None:
            continue
        ts.append(parse_ts(t))
        bases.append(base)
        ppms.append(ppm)

    if not ts:
        raise SystemExit("no est_base/est_ppm data for peer")

    try:
        import matplotlib.pyplot as plt
    except ImportError:
        raise SystemExit("matplotlib is required to output graphs.")

    plt.figure(figsize=(12, 4))
    plt.plot(ts, bases, linewidth=1, label="base")
    plt.plot(ts, ppms, linewidth=1, label="ppm")
    plt.xlabel("time")
    plt.ylabel("fee")
    plt.title(args.peer)
    plt.legend()
    plt.tight_layout()
    prefix = args.peer[:8]
    out_path = args.out or f"{prefix}-baseppm.png"
    plt.savefig(out_path, dpi=150)

    if args.show:
        plt.show()


if __name__ == "__main__":
    main()
